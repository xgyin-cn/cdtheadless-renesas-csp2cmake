{
  "name": "cdtheadlessbuild-renesascsp2cmake",
  "displayName": "cdtheadlessbuild-renesascsp2cmake",
  "publisher": "wwz",
  "description": "A tool to use CDT headless build mode and Renesas CS+ translate to CMake",
  "version": "0.1.5",
  "repository": "https://github.com/wang-zhuo996/cdtheadless-renesas-csp2cmake",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "twxs.cmake",
    "ms-vscode.cmake-tools",
    "renesaselectronicscorporation.renesas-build-utilities"
  ],
  "activationEvents": [
    "workspaceContains:**/.project",
    "workspaceContains:**/.cproject",
    "workspaceContains:.project",
    "workspaceContains:.cproject",
    "workspaceContains:*.mtpj"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cdtheadlessbuild.helloWorld",
        "title": "Hello World",
        "icon": {
          "light": "codicon-play-light",
          "dark": "codicon-play-dark"
        }
      },
      {
        "command": "SearchedProjectTree.buildProject",
        "title": "Build Project",
        "icon": "$(play)"
      },
      {
        "command": "RenesasCSP2CMake.buildProject",
        "title": "Build Project",
        "icon": "$(build)"
      },
      {
        "command": "SearchedProjectTree.buildAllProject",
        "title": "Build All Project",
        "icon": "$(run-all)"
      },
      {
        "command": "SearchedProjectTree.refreshEntry",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "RenesasCSP2CMake.refreshEntry",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "RenesasCSP2CMake.setCurrentProject",
        "title": "Set as Active Project",
        "icon": "$(play)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cdtheadlessbuild-projectlist",
          "title": "Eclipse CDT",
          "icon": "./icons/eclipse-11-logo-svg-vector.svg"
        },
        {
          "id": "renesas-csp2cmake-projectlist",
          "title": "Renesas CSP2CMake",
          "icon": "./icons/Renesas-memory.png"
        }
      ]
    },
    "views": {
      "cdtheadlessbuild-projectlist": [
        {
          "id": "SearchedProjectTree",
          "name": "Eclipse CDT 编译器项目树",
          "icon": ""
        }
      ],
      "renesas-csp2cmake-projectlist": [
        {
          "id": "RenesasCSP2CMakeConfig",
          "name": "CS+ Cmake Builder Config",
          "icon": ""
        },
        {
          "id": "RenesasCSP2CMake",
          "name": "CS+ Cmake Builder",
          "icon": ""
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "SearchedProjectTree.refreshEntry",
          "when": "view == SearchedProjectTree",
          "group": "navigation"
        },
        {
          "command": "SearchedProjectTree.buildAllProject",
          "when": "view == SearchedProjectTree",
          "group": "navigation"
        },
        {
          "command": "RenesasCSP2CMake.refreshEntry",
          "when": "view == RenesasCSP2CMake",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "SearchedProjectTree.buildProject",
          "when": "view == SearchedProjectTree && viewItem != 'hasChildren'",
          "group": "inline"
        },
        {
          "command": "SearchedProjectTree.buildAllProject",
          "when": "view == SearchedProjectTree && viewItem == 'hasChildren'",
          "group": "inline"
        },
        {
          "command": "RenesasCSP2CMake.buildProject",
          "when": "view == RenesasCSP2CMake && viewItem != 'hasChildren'",
          "group": "inline"
        },
        {
          "command": "RenesasCSP2CMake.setCurrentProject",
          "when": "view == RenesasCSP2CMake && viewItem == 'hasChildren'",
          "group": "inline"
        }
      ]
    },
    "configuration": [
      {
        "title": "Eclipse CDT Configurations",
        "properties": {
          "cdtheadlessbuild.launchPath": {
            "type": "string",
            "default": "",
            "description": "设置Eclipse启动路径"
          },
          "cdtheadlessbuild.argsAdded": {
            "type": "array",
            "default": [],
            "description": "设置Eclipse启动 附加参数"
          }
        }
      },
      {
        "title": "Renesas CSP2CMake Configurations",
        "properties": {
          "renesas.ccrh_toolchain_path": {
            "type": "string",
            "default": "",
            "description": "设置CCRH Toolchain路径"
          }
        }
      },
      {
        "title": "S-Record Reformat Configurations",
        "properties": {
          "srecordReformat.segDataFormat": {
            "type": "array",
            "default": [
              "S2"
            ],
            "enum": [
              "S1",
              "S2",
              "S3"
            ],
            "description": "设置S-Record重格式化输出的段数据格式，默认为S1"
          },
          "srecordReformat.segDataLength": {
            "type": "integer",
            "default": 16,
            "description": "设置S-Record重格式化输出的段数据长度，默认为16"
          },
          "srecordReformat.segDataFill": {
            "type": "integer",
            "default": 0,
            "description": "设置S-Record重格式化输出的段数据填充字节，默认为0"
          },
          "srecordReformat.segDataMinInterval": {
            "type": "integer",
            "default": 200,
            "description": "设置S-Record重格式化输出的段数据最小间隔，默认为200"
          }
        }
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.13.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.36",
    "ejs": "^5.0.2",
    "xml2js": "^0.6.2"
  }
}